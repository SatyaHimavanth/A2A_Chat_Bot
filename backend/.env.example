# Database
DATABASE_URL="sqlite:///./chatbot.db"

# Auth
SECRET_KEY="change-me-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="120"
REFRESH_TOKEN_EXPIRE_DAYS="30"

# Agent status checks
AGENT_STATUS_CHECK_TIMEOUT_SECONDS="12"
AGENT_STATUS_CACHE_TTL_SECONDS="30"

# Stream/A2A transport timeouts
STREAM_CONNECT_TIMEOUT_SECONDS="60"
STREAM_READ_TIMEOUT_SECONDS="240"

# Speech-to-text
STT_ENABLED="true"
STT_MODEL_ID="ibm-granite/granite-4.0-1b-speech"
STT_MODELS_DIR="./models"
STT_TARGET_SAMPLE_RATE="16000"
STT_PARTIAL_INTERVAL_MS="1500"
STT_DEFAULT_PAUSE_MS="1600"
STT_PARTIAL_WINDOW_SECONDS="8"
STT_SILENCE_RMS_THRESHOLD="0.012"
STT_ENDPOINT_SILENCE_MS="1200"
STT_NOISE_GATE_THRESHOLD="0.015"
STT_MIN_VOICED_RATIO="0.08"
HF_TOKEN=""
STT_WHISPER_TASK="translate"
STT_WHISPER_SOURCE_LANGUAGE=""
STT_MAX_NEW_TOKENS="512"
